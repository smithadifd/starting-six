# ===========================================
# Starting Six - Environment Configuration
# ===========================================
# Copy this to .env.local (dev) or .env.production (deploy)
# NEVER commit .env.local or .env.production to git

# Database
DATABASE_URL=./data/starting-six.db

# Authentication
# Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# App Configuration
# Production: https://starting-six.home (behind Caddy reverse proxy)
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000