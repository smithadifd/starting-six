# Starting Six — Production Environment
# Copy to .env.production and fill in values before deploying.

# Database (inside Docker container)
DATABASE_URL=/app/data/starting-six.db

# Authentication (required — generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://starting-six.home

# App URL (also passed as Docker build arg, inlined by Next.js at build time)
APP_URL=https://starting-six.home
NEXT_PUBLIC_APP_URL=https://starting-six.home
